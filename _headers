# docs/performance-cloudflare-cache.md のキャッシュルールも併用してください。

/eisei1-*.js
  Cache-Control: public, max-age=31536000, immutable

/site-analytics.js
  Cache-Control: public, max-age=31536000, immutable

/site-theme.css
  Cache-Control: public, max-age=31536000, immutable

/site-pages.css
  Cache-Control: public, max-age=31536000, immutable

/site-config.js
  Cache-Control: public, max-age=31536000, immutable

/site-q-index.js
  Cache-Control: public, max-age=31536000, immutable

/site-terms-index.js
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/about.html
  Cache-Control: public, max-age=3600

/privacy.html
  Cache-Control: public, max-age=3600
